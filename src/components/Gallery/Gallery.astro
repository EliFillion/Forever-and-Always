---
import SectionHeading from "../UI/SectionHeading.astro";
import GalleryImage from "./GalleryImage.astro";

interface Props {
  data: {
    heading: {
      eyebrow: string;
      title: string;
    };
    photoAlt: string;
    closingVerse: string;
    closingReference: string;
  };
}

const { data } = Astro.props;
---

<section id="gallery" class="bg-white py-32">

  <div class="container max-w-6xl">

    <SectionHeading
      eyebrow={data.heading.eyebrow}
      title={data.heading.title}
    />

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">

      {Array.from({ length: 12 }, (_, index) => (
        <GalleryImage image={`/images/gallery/${index + 1}.jpg`} alt={`${data.photoAlt} ${index + 1}`} />
      ))}

    </div>

    <div
      data-aos="fade-up"
      data-aos-duration="1000"
      class="mx-auto mt-20 max-w-3xl text-center"
    >

      <p class="text-3xl italic text-[var(--forest)]">
        "{data.closingVerse}"
      </p>

      <p class="mt-4 text-[var(--gold)]">
        {data.closingReference}
      </p>

    </div>

  </div>

</section>

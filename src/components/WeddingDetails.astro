---
import {
  CalendarDays,
  Clock3,
  MapPinned,
  UtensilsCrossed,
  Shirt,
  ExternalLink,
  Heart,
  Church,
  Coffee,
  PartyPopper,
} from "lucide-astro";

type EventIcon = "ceremony" | "coffee" | "reception" | "celebration";

interface Props {
  data: {
    date: string;
    eyebrow: string;
    title: string;
    intro: string;
    day: string;
    location: string;
    locationArea: string;
    dressCodeLabel: string;
    dressCode: string;
    mapLabel: string;
    venueText: string;
    timelineTitle: string;
    events: readonly {
      time: string;
      label: string;
      icon: EventIcon;
    }[];
  };
}

const { data } = Astro.props;

const icons = {
  ceremony: Church,
  coffee: Coffee,
  reception: UtensilsCrossed,
  celebration: PartyPopper,
};
---

<section id="wedding" class="bg-white py-32">
  <div class="container max-w-6xl">

    <div data-aos="fade-up" class="mx-auto mb-20 max-w-3xl text-center">
      <p class="uppercase tracking-[0.45em] text-[var(--gold)]">{data.eyebrow}</p>
      <h2 class="mt-4 font-serif text-5xl text-[var(--forest)]">
        {data.title}
      </h2>
      <p class="mt-8 text-lg leading-8 text-gray-600">
        {data.intro}
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-2">

      <div data-aos="fade-right" class="rounded-3xl border border-gray-200 bg-[var(--cream)] p-10 shadow-lg">

        <div class="mb-8 flex items-center gap-4">
          <CalendarDays size={34} class="text-[var(--gold)]" />
          <div>
            <h3 class="font-serif text-3xl text-[var(--forest)]">{data.day}</h3>
            <p class="text-gray-600">{data.date}</p>
          </div>
        </div>

        <div class="space-y-8">

          <div class="flex items-start gap-4">
            <Clock3 size={24} class="mt-1 text-[var(--gold)]" />
            <div>
              <h4 class="font-semibold text-[var(--forest)]">{data.events[0].label}</h4>
              <p class="text-gray-700">{data.events[0].time}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <UtensilsCrossed size={24} class="mt-1 text-[var(--gold)]" />
            <div>
              <h4 class="font-semibold text-[var(--forest)]">{data.events[1].label}</h4>
              <p class="text-gray-700">{data.events[1].time}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <Heart size={24} class="mt-1 text-[var(--gold)]" />
            <div>
              <h4 class="font-semibold text-[var(--forest)]">{data.events[2].label}</h4>
              <p class="text-gray-700">{data.events[2].time}</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <Shirt size={24} class="mt-1 text-[var(--gold)]" />
            <div>
              <h4 class="font-semibold text-[var(--forest)]">{data.dressCodeLabel}</h4>
              <p class="text-gray-700">{data.dressCode}</p>
            </div>
          </div>

        </div>
      </div>

      <div data-aos="fade-left" class="rounded-3xl bg-[var(--forest)] p-10 text-white shadow-xl">

        <div class="mb-8 flex items-center gap-4">
          <MapPinned size={34} class="text-[var(--gold)]" />
          <div>
            <h3 class="font-serif text-3xl">{data.location}</h3>
            <p class="text-gray-200">{data.locationArea}</p>
          </div>
        </div>

        <p class="leading-8 text-gray-100">
          {data.venueText}
        </p>

        <a href="https://maps.app.goo.gl/6u8A1tPqC26uttRK9"
           target="_blank"
           class="mt-10 inline-flex items-center gap-3 rounded-full bg-[var(--gold)] px-8 py-4 font-semibold text-white transition hover:scale-105 hover:opacity-90">
          {data.mapLabel}
          <ExternalLink size={18} />
        </a>

      </div>

    </div>

    <div data-aos="fade-up" class="mt-24">

      <h3 class="mb-16 text-center font-serif text-4xl text-[var(--forest)]">
        {data.timelineTitle}
      </h3>

      <div class="relative">
        <div class="absolute left-0 right-0 top-7 hidden h-1 rounded-full bg-[var(--gold)]/30 md:block"></div>

        <div class="grid gap-10 md:grid-cols-4">

          {data.events.map((event) => {
            const Icon = icons[event.icon] ?? PartyPopper;
            return (
              <div class="text-center">
                <div class="relative z-10 mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-full bg-[var(--gold)] text-white shadow-lg"><Icon size={24} /></div>
                <h4 class="font-serif text-2xl text-[var(--forest)]">{event.time}</h4>
                <p class="mt-2 text-gray-700">{event.label}</p>
              </div>
            );
          })}

        </div>
      </div>

    </div>

  </div>
</section>

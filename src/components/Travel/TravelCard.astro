---
interface Props {
  title: string;
  description: string;
  image: string;
  linkText?: string;
  linkUrl?: string;
}

const {
  title,
  description,
  image,
  linkText,
  linkUrl,
} = Astro.props;
---

<div
  data-aos="fade-up"
  class="overflow-hidden rounded-3xl bg-white shadow-xl transition hover:-translate-y-2 hover:shadow-2xl"
>

  <img
    src={image}
    alt={title}
    class="h-72 w-full object-cover"
  />

  <div class="p-8">

    <h3 class="text-3xl font-serif text-[var(--forest)]">
      {title}
    </h3>

    <p class="mt-6 leading-8 text-gray-700">
      {description}
    </p>

    {linkText && linkUrl && (
      <a
        href={linkUrl}
        target="_blank"
        rel="noreferrer"
        class="mt-6 inline-flex items-center justify-center rounded-full bg-[var(--forest)] px-5 py-3 text-sm font-semibold uppercase tracking-[0.25em] text-white transition hover:bg-[var(--forest)]/90"
      >
        {linkText}
      </a>
    )}

  </div>

</div>
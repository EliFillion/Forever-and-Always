---
import SectionHeading from "../UI/SectionHeading.astro";
import TravelCard from "./TravelCard.astro";

interface Props {
  data: {
    heading: {
      eyebrow: string;
      title: string;
    };
    cards: readonly {
      image: string;
      title: string;
      description: string;
      linkText?: string;
      linkUrl?: string;
    }[];
  };
}

const { data } = Astro.props;
---

<section id="travel" class="bg-[var(--cream)] py-32">

  <div class="container max-w-6xl">

    <SectionHeading
      eyebrow={data.heading.eyebrow}
      title={data.heading.title}
    />

    <div class="grid gap-10 lg:grid-cols-3">

      {data.cards.map((card) => (
        <TravelCard {...card} />
      ))}

    </div>

  </div>

</section>

---
import SectionHeading from "../UI/SectionHeading.astro";
import StoryCard from "./StoryCard.astro";

interface Props {
  data: {
    heading: {
      eyebrow: string;
      title: string;
      verse: string;
      reference: string;
    };
    cards: readonly {
      image: string;
      title: string;
      date: string;
      text: string;
      reverse?: boolean;
    }[];
    closingReference: string;
    closingVerse: string;
  };
}

const { data } = Astro.props;
---

<section id="story" class="bg-[var(--cream)] py-32">

  <div class="container max-w-6xl">

    <SectionHeading
      eyebrow={data.heading.eyebrow}
      title={data.heading.title}
      verse={data.heading.verse}
      reference={data.heading.reference}
    />

    {data.cards.map((card) => (
      <StoryCard
        image={card.image}
        title={card.title}
        date={card.date}
        text={card.text}
        reverse={card.reverse}
      />
    ))}

    <div class="mt-8 border-t border-[var(--forest)]/15 pt-8 text-center">
      <p class="text-sm uppercase tracking-[0.35em] text-[var(--gold)]">
        {data.closingReference}
      </p>
      <p class="mt-4 font-serif text-2xl italic text-[var(--forest)] sm:text-3xl">
        "{data.closingVerse}"
      </p>
    </div>

  </div>

</section>

---
import MainLayout from "../../layouts/MainLayout.astro";

import Navigation from "../../components/Navigation.astro";
import Hero from "../../components/Hero.astro";
import StoryPreview from "../../components/Story/StoryPreview.astro";
import WeddingDetails from "../../components/WeddingDetails.astro";
import Accommodations from "../../components/Accommodations/Accommodations.astro";
import Travel from "../../components/Travel/Travel.astro";
import Gifts from "../../components/Gifts/Gifts.astro";
import FAQ from "../../components/FAQ/FAQ.astro";
import Gallery from "../../components/Gallery/Gallery.astro";
import { getSite, locales } from "../../data/site";

const locale = "fr";
const page = getSite(locale);
---

<MainLayout title={page.metaTitle} lang={locales[locale].htmlLang}>

  <Navigation locale={locale} links={page.navigation} rsvpLabel={page.rsvpLabel} shortDate={page.wedding.shortDate} />
  <Hero data={page} rsvpPath="/fr/rsvp" />
  <StoryPreview data={page.story} />
  <WeddingDetails data={page.weddingDetails} />
  <Accommodations data={page.accommodations} />
  <Travel data={page.travel} />
  <Gifts data={page.gifts} />
  <FAQ data={page.faq} />
  <Gallery data={page.gallery} />

  <footer
    class="bg-[var(--forest-dark)] py-24 text-[var(--cream)] md:py-32"
    data-aos="fade-up"
    data-aos-duration="1600"
    data-aos-delay="120"
    data-aos-easing="ease-out-cubic"
  >
    <div class="container max-w-4xl text-center">
      <p class="mb-8 text-lg leading-8 text-[var(--cream)]/90 md:text-xl">
        {page.footer.thanks}
      </p>

      <p class="mx-auto max-w-3xl text-base leading-8 text-[var(--cream)]/85 md:text-lg">
        {page.footer.message}
      </p>

      <div class="mx-auto mt-10 h-px w-24 bg-[var(--gold)]/80"></div>

      <p class="mt-10 font-serif text-4xl tracking-[0.22em] text-[var(--cream)] md:text-5xl">
        {page.wedding.title}
      </p>

      <p class="mt-6 font-serif text-2xl tracking-[0.3em] text-[var(--cream)] md:text-3xl">
        E <span class="mx-2 text-[var(--gold)]">♡</span> D
      </p>

      <p class="mt-6 text-sm uppercase tracking-[0.35em] text-[var(--cream)]/80 md:text-base">
        {page.wedding.date}
      </p>
    </div>
  </footer>

</MainLayout>

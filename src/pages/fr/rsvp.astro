---
import MainLayout from "../../layouts/MainLayout.astro";
import Navigation from "../../components/Navigation.astro";
import { getSite, locales } from "../../data/site";

const locale = "fr";
const page = getSite(locale);
---

<MainLayout title={`RSVP | ${page.couple.groom} & ${page.couple.bride}`} lang={locales[locale].htmlLang}>

  <Navigation locale={locale} links={page.navigation} rsvpLabel={page.rsvpLabel} shortDate={page.wedding.shortDate} />

  <section class="min-h-screen bg-[var(--cream)] py-40">

    <div class="container max-w-3xl">

      <div data-aos="fade-up" class="mb-16 text-center">

        <p class="uppercase tracking-[0.45em] text-[var(--gold)]">
          RSVP
        </p>

        <h1 class="mt-4 font-serif text-5xl text-[var(--forest)]">
          Nous aimerions célébrer avec vous
        </h1>

        <p class="mt-8 text-lg leading-8 text-gray-600">
          Merci de répondre avant le <strong>1er septembre 2026</strong>.
          Nous avons très hâte de célébrer cette journée spéciale ensemble!
        </p>

      </div>

      <form
        action="https://formspree.io/f/mykqnzga"
        method="POST"
        class="space-y-8 rounded-3xl bg-white p-10 shadow-xl"
        id="rsvp-form"
        novalidate
      >

        <div
          id="form-error"
          class="hidden rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-semibold text-red-700"
          role="alert"
        >
          Veuillez remplir tous les champs avant d'envoyer votre réponse.
        </div>

        <div data-field>
          <label for="name" class="mb-2 block font-semibold text-[var(--forest)]">Nom complet</label>
          <input id="name" name="name" type="text" class="w-full rounded-xl border p-4" placeholder="Votre nom" required data-required-field aria-describedby="name-error" />
          <p id="name-error" class="mt-2 hidden text-sm font-semibold text-red-600" data-field-error>
            Veuillez entrer votre nom complet.
          </p>
        </div>

        <div data-field>
          <label for="attendance" class="mb-2 block font-semibold text-[var(--forest)]">Serez-vous présent?</label>
          <select id="attendance" name="attendance" class="w-full rounded-xl border p-4" required data-required-field aria-describedby="attendance-error">
            <option value="">Choisir une option</option>
            <option value="Joyfully Accepts">Accepte avec joie</option>
            <option value="Regretfully Declines">Décline avec regret</option>
          </select>
          <p id="attendance-error" class="mt-2 hidden text-sm font-semibold text-red-600" data-field-error>
            Veuillez indiquer si vous serez présent.
          </p>
        </div>

        <div data-field>
          <label for="guests" class="mb-2 block font-semibold text-[var(--forest)]">Nombre d'invités</label>
          <input id="guests" name="guests" type="number" min="1" max="15" step="1" inputmode="numeric" class="w-full rounded-xl border p-4" value="1" required data-required-field data-integer-field aria-describedby="guests-error" />
          <p id="guests-error" class="mt-2 hidden text-sm font-semibold text-red-600" data-field-error>
            Veuillez entrer un nombre entier d'invités.
          </p>
        </div>

        <div data-field>
          <label for="message" class="mb-2 block font-semibold text-[var(--forest)]">Message pour le couple</label>
          <textarea id="message" name="message" rows="5" class="w-full rounded-xl border p-4" placeholder="Écrivez un petit mot" required data-required-field aria-describedby="message-error"></textarea>
          <p id="message-error" class="mt-2 hidden text-sm font-semibold text-red-600" data-field-error>
            Veuillez laisser un message pour le couple.
          </p>
        </div>

        <div id="form-success" class="hidden rounded-2xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
          Merci! Votre RSVP a bien été envoyé.
        </div>

        <button
          type="submit"
          class="rounded-full bg-[var(--gold)] px-8 py-4 font-semibold text-white transition hover:scale-105"
        >
          Envoyer le RSVP
        </button>

      </form>

    </div>

  </section>

  <script>
    const form = document.getElementById('rsvp-form');
    const formError = document.getElementById('form-error');
    const successMessage = document.getElementById('form-success');

    if (form && formError && successMessage) {
      const requiredFields = Array.from(form.querySelectorAll('[data-required-field]'));

      const markField = (field) => {
        const isMissing = !field.value.trim();
        const mustBeInteger = field.hasAttribute('data-integer-field');
        const numberValue = Number(field.value);
        const isInvalidInteger = !isMissing && mustBeInteger && (!Number.isInteger(numberValue) || numberValue < Number(field.min) || numberValue > Number(field.max));
        const hasError = isMissing || isInvalidInteger;
        const fieldGroup = field.closest('[data-field]');
        const fieldError = fieldGroup?.querySelector('[data-field-error]');

        field.classList.toggle('border-red-400', hasError);
        field.classList.toggle('bg-red-50/50', hasError);
        field.classList.toggle('ring-2', hasError);
        field.classList.toggle('ring-red-100', hasError);
        field.setAttribute('aria-invalid', String(hasError));
        fieldError?.classList.toggle('hidden', !hasError);

        return !hasError;
      };

      requiredFields.forEach((field) => {
        field.addEventListener('input', () => markField(field));
        field.addEventListener('change', () => markField(field));
      });

      form.addEventListener('submit', (event) => {
        const missingFields = requiredFields.filter((field) => !markField(field));

        if (missingFields.length > 0) {
          event.preventDefault();
          successMessage.classList.add('hidden');
          formError.classList.remove('hidden');
          missingFields[0].focus();
          return;
        }

        formError.classList.add('hidden');
        successMessage.classList.remove('hidden');
      });
    }
  </script>

</MainLayout>
